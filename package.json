{
  "name": "ghakit",
  "version": "1.0.0",
  "description": "A toolkit for building GitHub Actions with no runtime dependencies",
  "keywords": [
    "github",
    "actions",
    "toolkit"
  ],
  "homepage": "https://threeal.github.io/ghakit",
  "bugs": {
    "url": "https://github.com/threeal/ghakit/issues",
    "email": "alfi.maulana.f@gmail.com"
  },
  "repository": "github:threeal/ghakit",
  "license": "MIT",
  "author": "Alfi Maulana <alfi.maulana.f@gmail.com>",
  "exports": {
    "./exec": {
      "types": "./dist/exec.d.ts",
      "import": "./dist/exec.js"
    },
    "./io": {
      "types": "./dist/io.d.ts",
      "import": "./dist/io.js"
    },
    "./log": {
      "types": "./dist/log.d.ts",
      "import": "./dist/log.js"
    },
    "./vars": {
      "types": "./dist/vars.d.ts",
      "import": "./dist/vars.js"
    }
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=24"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.16.0",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.7.0"
}
