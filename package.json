{
  "name": "gha-utils",
  "version": "0.4.1",
  "description": "A minimalistic utility package for developing GitHub Actions",
  "keywords": [
    "github",
    "actions",
    "utility"
  ],
  "homepage": "https://threeal.github.io/gha-utils",
  "bugs": {
    "url": "https://github.com/threeal/gha-utils/issues",
    "email": "alfi.maulana.f@gmail.com"
  },
  "repository": "github:threeal/gha-utils",
  "license": "MIT",
  "author": "Alfi Maulana <alfi.maulana.f@gmail.com>",
  "exports": {
    "./exec": {
      "default": "./dist/exec.js",
      "types": "./dist/exec.d.ts"
    },
    "./io": {
      "default": "./dist/io.js",
      "types": "./dist/io.d.ts"
    },
    "./log": {
      "default": "./dist/log.js",
      "types": "./dist/log.d.ts"
    },
    "./vars": {
      "default": "./dist/vars.js",
      "types": "./dist/vars.d.ts"
    }
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^10.4.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.0.15"
  },
  "packageManager": "pnpm@10.33.4"
}
